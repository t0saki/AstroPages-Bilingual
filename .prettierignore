# Ignore everything
/*

# Except these files & folders
!/src
!/public
!/.github
!/scripts
!tsconfig.json
!astro.config.ts
!package.json
!.prettierrc
!eslint.config.js
!README.md
!.vscode

# Ignore MDX files
*.mdx

# Python has no prettier parser
*.py

# Don't reformat authored blog/page content. Prettier mangles markdown autolink
# URLs that contain underscores, e.g. <https://…/File_Name_(1893_Fig_11).svg>,
# by inserting emphasis escapes and breaking the link.
/src/content