---
import type { GalleryAlbum } from "@/types/gallery";
import { useTranslations } from "@/i18n";
import config from "@/config";

interface Props {
  albums: GalleryAlbum[];
}

const { albums } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const dateFormatter = new Intl.DateTimeFormat(locale, {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Localized PhotoSwipe button titles / error message, read by the client script.
const pswpStrings = JSON.stringify({
  close: t.a11y.lightboxClose,
  zoom: t.a11y.lightboxZoom,
  prev: t.a11y.lightboxPrev,
  next: t.a11y.lightboxNext,
  error: t.a11y.lightboxError,
});
---

{
  albums.length === 0 ? (
    <p class="text-muted-foreground py-16 text-center italic">
      {t.pages.galleryEmpty}
    </p>
  ) : (
    <div class="gallery" data-pswp-strings={pswpStrings}>
      {albums.map(album => (
        <section class="mb-12">
          <div class="g-head mb-3 flex items-baseline justify-between gap-4">
            <h2 class="text-lg font-medium">
              <a
                href={album.post.url}
                class="text-foreground hover:text-accent underline decoration-dashed decoration-1 underline-offset-4 transition-colors"
              >
                {album.post.title}
              </a>
            </h2>
            <time
              class="text-muted-foreground shrink-0 text-sm"
              datetime={album.post.date.toISOString()}
            >
              {dateFormatter.format(album.post.date)}
            </time>
          </div>
          <div class="g-grid">
            {album.photos.map(photo => (
              <a
                class="g-item"
                href={photo.src}
                target="_blank"
                rel="noopener noreferrer"
                style={{ "--ar": photo.width / photo.height }}
                data-pswp-width={photo.width}
                data-pswp-height={photo.height}
                data-exif-camera={photo.camera ?? ""}
                data-exif-settings={photo.settings ?? ""}
              >
                <img
                  src={photo.thumbSrc}
                  alt={photo.alt}
                  width={photo.width}
                  height={photo.height}
                  loading="lazy"
                  decoding="async"
                />
                {(photo.alt || photo.camera || photo.settings) && (
                  <div class="g-overlay" aria-hidden="true">
                    {photo.alt && <span class="g-caption">{photo.alt}</span>}
                    {photo.camera && <span class="g-meta">{photo.camera}</span>}
                    {photo.settings && (
                      <span class="g-meta">{photo.settings}</span>
                    )}
                  </div>
                )}
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  )
}

<style>
  /* CSS-only justified grid: each item grows in proportion to its aspect ratio
     so rows share a common height; the ::after spacer keeps the last (partial)
     row left-aligned instead of stretching its items across the full width. */
  /* Album-app breakout: the photo rows and each album's title/date row
     escape the text column up to ~80% of the viewport (capped for ultrawide
     monitors) and re-center themselves, so titles/dates hug the grid edges;
     the page title/description above stay at the regular content width. */
  .g-head,
  .g-grid {
    --g-wide: max(100%, min(80vw, 100rem));
    width: var(--g-wide);
    margin-inline: calc((100% - var(--g-wide)) / 2);
  }
  .g-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .g-grid::after {
    content: "";
    flex-grow: 1000000;
  }
  /* Album-app feel on phones: photo rows bleed to the screen edges by
     cancelling the page's 1rem side padding; titles/dates stay padded. */
  @media (width < 40rem) {
    .g-head {
      width: 100%;
      margin-inline: 0;
    }
    .g-grid {
      width: calc(100% + 2rem);
      margin-inline: -1rem;
    }
    .g-grid .g-item {
      border-radius: 0;
    }
  }
  .g-item {
    position: relative;
    aspect-ratio: var(--ar);
    flex-grow: calc(var(--ar) * 100);
    flex-basis: calc(var(--ar) * 11rem);
    overflow: hidden;
    border-radius: 0.25rem;
    /* Doubles as a loading placeholder before the thumbnail paints. */
    background-color: var(--color-muted);
  }
  .g-item img {
    display: block;
    height: 100%;
    width: 100%;
    object-fit: cover;
  }

  .g-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.125rem;
    padding: 0.5rem 0.625rem;
    background: linear-gradient(
      to top,
      rgb(0 0 0 / 0.72) 0%,
      rgb(0 0 0 / 0.35) 35%,
      transparent 70%
    );
    color: #fff;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }
  /* Reveal on hover only for real pointers; touch devices rely on the lightbox. */
  @media (hover: hover) and (pointer: fine) {
    .g-item:hover .g-overlay {
      opacity: 1;
    }
  }
  /* Keyboard parity: focusing an item shows its overlay + a visible outline. */
  .g-item:focus-visible {
    outline: 2px dashed var(--color-accent);
    outline-offset: 2px;
  }
  .g-item:focus-visible .g-overlay {
    opacity: 1;
  }
  .g-caption {
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.3;
    text-shadow: 0 1px 2px rgb(0 0 0 / 0.4);
  }
  .g-meta {
    overflow: hidden;
    font-size: 0.6875rem;
    line-height: 1.3;
    text-overflow: ellipsis;
    white-space: nowrap;
    opacity: 0.75;
    text-shadow: 0 1px 2px rgb(0 0 0 / 0.4);
  }
</style>

<script>
  import type PhotoSwipeLightbox from "photoswipe/lightbox";
  import { createViewer, parseViewerStrings } from "@/scripts/photoViewer";

  let lightbox: PhotoSwipeLightbox | null = null;

  function destroyLightbox() {
    lightbox?.destroy();
    lightbox = null;
  }

  function initGallery() {
    // Re-init cleanly across view transitions.
    destroyLightbox();

    if (!document.querySelector(".g-grid")) return;

    lightbox = createViewer(
      {
        // Each `.g-grid` is an independent album; arrows stay within one album.
        gallery: ".g-grid",
        children: "a.g-item",
      },
      parseViewerStrings(
        document.querySelector<HTMLElement>("[data-pswp-strings]")
      )
    );
    lightbox.init();
  }

  document.addEventListener("astro:page-load", initGallery);
  document.addEventListener("astro:before-swap", destroyLightbox);
</script>
