---
import IconLanguage from "@/assets/icons/IconLanguage.svg";
import { getAlternatePath, type Locale } from "@/i18n/helpers";
import { stripBase } from "@/utils/withBase";
import config from "@/config";

const locale = (Astro.currentLocale ?? config.site.lang) as Locale;
const target: Locale = locale === "zh" ? "en" : "zh";
const targetLabel = target === "zh" ? "中文" : "EN";
const label = target === "zh" ? "切换到中文" : "Switch to English";

// Map the current path to its counterpart in the other language.
const currentPath = stripBase(Astro.url.pathname);
const href = getAlternatePath(currentPath, target);
---

<a
  href={href}
  data-lang-switch={target}
  hreflang={target}
  class="focus-outline hover:text-accent flex items-center gap-1 p-3 sm:p-1"
  title={label}
  aria-label={label}
>
  <IconLanguage class="size-6 sm:size-5" />
  {/* Desktop: icon only (aligned with the other nav icons).
      Mobile menu: show the language label next to the icon. */}
  <span class="text-sm sm:sr-only">{targetLabel}</span>
</a>

<script>
  // Remember the manual language choice so the redirect script in Layout
  // honours it on subsequent visits.
  function bindLangSwitch() {
    document
      .querySelectorAll<HTMLAnchorElement>("a[data-lang-switch]")
      .forEach(a => {
        a.addEventListener("click", () => {
          const target = a.getAttribute("data-lang-switch");
          if (target) localStorage.setItem("preferredLang", target);
        });
      });
  }
  bindLangSwitch();
  document.addEventListener("astro:after-swap", bindLangSwitch);
</script>
